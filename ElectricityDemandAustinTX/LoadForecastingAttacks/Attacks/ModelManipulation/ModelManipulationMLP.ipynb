    "yp_te = hourly_res_norm.loc['2017':,'load']\n",
    "y_init_val = np.hstack([y_tr[-1], validate.iloc[167::168,0].values])\n",
    "y_init_te = np.hstack([y_val[-1], test.iloc[167::168,0].values])"
