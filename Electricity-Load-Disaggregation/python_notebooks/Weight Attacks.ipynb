    "def construct_dataset(x: np.ndarray,\n",
    "                      y: np.ndarray, window_size=5, shift=1, stride=1, batch_size=32, n_targets=n_targets):\n",
    "    \n",
    "    def make_window_dataset(ds, window_size, shift, stride):\n",
    "        windows = ds.window(window_size, shift=shift, stride=stride)\n",
    "\n",
    "        def sub_to_batch(sub):\n",
    "            return sub.batch(window_size, drop_remainder=True)\n",
    "\n",
    "        windows = windows.flat_map(sub_to_batch)\n",
    "        return windows\n",
    "\n",
    "    dataset_x = tf.data.Dataset.from_tensor_slices(x)\n",
    "    dataset_ys_1 = tf.data.Dataset.from_tensor_slices(y)\n",
    "\n",
    "    ts_dataset = make_window_dataset(dataset_x, window_size=window_size, shift=shift, stride=stride)\n",
    "    ts_dataset_ys = make_window_dataset(dataset_ys_1, window_size=window_size, shift=shift, stride=stride)\n",
    "\n",
    "    total_dataset = tf.data.Dataset.zip((ts_dataset, ts_dataset_ys)).batch(batch_size, drop_remainder=True)#.shuffle(buffer_size=50)\n",
    "    total_dataset = total_dataset.cache()                          # keep all windows in RAM (or filename.cache('path'))\n",
    "    total_dataset = total_dataset.prefetch(tf.data.AUTOTUNE)       # overlap prep + model execution\n",
    "    return total_dataset\n",
    "\n",
    "train_dataset = construct_dataset(train_data.iloc[:, -n_x_vars:], train_data.iloc[:, :-n_x_vars], window_size, window_size//15, batch_size=batch_size)\n",
    "val_dataset = construct_dataset(val_data.iloc[:, -n_x_vars:], val_data.iloc[:, :-n_x_vars], window_size, window_size//15, batch_size=batch_size)\n"
   ]
