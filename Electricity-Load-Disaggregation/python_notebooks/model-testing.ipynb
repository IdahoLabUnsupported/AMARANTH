    "def plateau_score(x, alpha=1e-2):\n",
    "    # x: [B, T, 1]\n",
    "    diffs = x[:,1:,:] - x[:,:-1,:] # shape [B, T-1, 1]\n",
    "    # exp(–α|Δ|) is ≈1 when Δ≈0, and →0 as |Δ| grows\n",
    "    return tf.reduce_mean(tf.exp(-alpha * tf.abs(diffs)))\n",
    "\n",
    "def input_loss(y_true, y_pred, target_idx):\n",
    "    # p_scores = plateau_score(y_pred)\n",
    "    # Reshape y_pred to ensure the correct shape\n",
    "    y_pred = tf.reshape(y_pred, (-1, n_targets))\n",
    "    \n",
    "    # Extract the target output\n",
    "    target_output = y_pred[:, target_idx]\n",
    "    \n",
    "    # Extract the other outputs\n",
    "    other_outputs = tf.concat([y_pred[:, :target_idx], y_pred[:, target_idx+1:]], axis=1)\n",
    "    \n",
    "    # Maximize the target output (minimize its negative)\n",
    "    max_target_loss = -tf.reduce_mean(target_output) * 15\n",
    "    \n",
    "    # Minimize the other outputs\n",
    "    min_other_loss = tf.reduce_mean(other_outputs) \n",
    "    \n",
    "    # Combine the losses\n",
    "    total_loss = max_target_loss + min_other_loss #- p_scores * 10\n",
    "    return total_loss\n",
    "\n",
    "\n",
    "pos_vals = tf.constant(train_data.iloc[0:1440, -2:].values[np.newaxis, :, :])\n",
    "\n",
    "proxy = tf.Variable(tf.clip_by_value(tf.random.normal((1, window_size, 1), mean=300., stddev=700.0), 0, 10000), trainable=True)\n",
    "\n",
    "def get_tgt_input():\n",
    "    return tf.keras.layers.LeakyReLU(0.005)(proxy) # tf.sigmoid(proxy) * (4000 - 0)\n",
    "# tgt_input = tf.Variable(tf.math.log(train_data.iloc[1440:1440*2, -4:-3].values[np.newaxis, :, :] + 1), trainable=True)\n",
    "\n",
    "tgt_class_idx = 2\n",
    "mask = np.zeros((n_targets,))\n",
    "mask[tgt_class_idx] = 1\n",
    "tgt_mask = tf.constant(mask, dtype=tf.float32)\n",
    "input_optimizer = tf.keras.optimizers.Adam(learning_rate=5.)"
