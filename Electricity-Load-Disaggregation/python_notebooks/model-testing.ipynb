    "# Custom R2 score\n",
    "@tf.keras.utils.register_keras_serializable()\n",
    "def r2_score(y_true, y_pred):\n",
    "    \"\"\"\n",
    "    Custom R2 Score metric for each target individually and then aggregate them.\n",
    "    \n",
    "    Args:\n",
    "    y_true: Tensor of true values, shape (batch, sequence, n_targets)\n",
    "    y_pred: Tensor of predicted values, shape (batch, sequence, n_targets)\n",
    "    \n",
    "    Returns:\n",
    "    r2: Tensor containing the mean R2 score across all targets.\n",
    "    \"\"\"\n",
    "\n",
    "    SS_res = K.sum(K.square(y_true - y_pred), axis=(0, 1))\n",
    "    SS_tot = K.sum(K.square(y_true - K.mean(y_true, axis=(0, 1), keepdims=True)), axis=(0, 1))\n",
    "    \n",
    "    r2 = 1 - SS_res / (SS_tot + K.epsilon())\n",
    "    return K.mean(r2)\n",
    "\n",
    "model.compile(\n",
    "    optimizer=tf.keras.optimizers.Adam(learning_rate=5e-4),\n",
    "    loss={\n",
    "        \"time_output_out\": tf.keras.losses.MeanSquaredError(),\n",
    "        # \"time_output_agg\": tf.keras.losses.MeanSquaredError()\n",
    "    },\n",
    "    metrics={\n",
    "        \"time_output_out\": [tf.keras.metrics.RootMeanSquaredError(), r2_score],\n",
    "        # \"time_output_agg\": [tf.keras.metrics.RootMeanSquaredError(), r2_score]\n",
    "    }\n",
    ")"
   ]
  },
