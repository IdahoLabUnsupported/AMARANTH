    "four_app_train['sine_encoding'] = np.sin(2 * np.pi * four_app_train['minute_idx'])\n",
    "four_app_train['cosine_encoding'] = np.cos(2 * np.pi * four_app_train['minute_idx'])\n",
    "four_app_train.drop(['minute_idx'], axis=1, inplace=True)\n",
    "\n",
    "four_app_train = four_app_train.astype(np.float32)"
